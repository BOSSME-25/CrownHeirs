# ───────────────────────────────────────────────
# Crown Heirs Intranet — environment variables
# Copy to .env.local for local dev. In production,
# set these in the Vercel project settings.
# ───────────────────────────────────────────────

# Auth.js secret — generate with: npx auth secret
AUTH_SECRET=

# Google OAuth credentials (Google Cloud Console → Credentials → OAuth client ID)
# Authorized redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Who can SIGN IN (employees). Comma-separated.
# Anyone on these domains can access the site.
ALLOWED_DOMAINS=crownheirs.com
# Extra individual emails outside the domain (optional)
ALLOWED_EMAILS=

# Who can UPLOAD / manage documents (admins). Comma-separated.
ADMIN_EMAILS=emily@crownheirs.com,bethany@crownheirs.com

# Vercel Blob storage token — auto-provided in Vercel once you
# create a Blob store and connect it to this project.
BLOB_READ_WRITE_TOKEN=

# Public base URL of this site (used in notification email links).
APP_URL=https://crownteamhub.vercel.app

# Email notifications via Google Workspace SMTP (App Password).
SMTP_USER=notifications@crownheirs.com
SMTP_PASSWORD=
# Optional friendly From (defaults to SMTP_USER):
NOTIFY_FROM=Crown Heirs Team Hub <notifications@crownheirs.com>

# Square (KPI dashboard). Production access token + location from the
# Square Developer dashboard.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# 'production' or 'sandbox'
SQUARE_ENV=production

# Secret that protects the weekly-KPI cron endpoint. Set the same value
# in Vercel; Vercel Cron sends it automatically as a Bearer token.
CRON_SECRET=

# Key used to encrypt per-tenant secrets (POS tokens) stored in the DB.
# Any long random string. Required only to save integration tokens in-app.
APP_ENCRYPTION_KEY=

# Anthropic API key — powers the AI "Help me write" bio assistant.
# Optional; the feature only appears when this is set.
ANTHROPIC_API_KEY=
