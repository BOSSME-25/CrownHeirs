# ───────────────────────────────────────────────
# Crown Heirs Intranet — environment variables
# Copy to .env.local for local dev. In production,
# set these in the Vercel project settings.
# ───────────────────────────────────────────────

# Auth.js secret — generate with: npx auth secret
AUTH_SECRET=

# Google OAuth credentials (Google Cloud Console → Credentials → OAuth client ID)
# Authorized redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Who can SIGN IN (employees). Comma-separated.
# Anyone on these domains can access the site.
ALLOWED_DOMAINS=crownheirs.com
# Extra individual emails outside the domain (optional)
ALLOWED_EMAILS=

# Who can UPLOAD / manage documents (admins). Comma-separated.
ADMIN_EMAILS=emily@crownheirs.com,bethany@crownheirs.com

# Vercel Blob storage token — auto-provided in Vercel once you
# create a Blob store and connect it to this project.
BLOB_READ_WRITE_TOKEN=
